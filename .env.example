# Chave da API do Google Gemini (GRATUITA — veja como obter no README.md)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo usado para gerar/avaliar perguntas (gemini-2.5-flash está no tier gratuito)
# Se quiser ainda mais velocidade (trocando um pouco de qualidade/raciocínio),
# use gemini-2.5-flash-lite — também gratuito e mais rápido.
GEMINI_MODEL=gemini-2.5-flash

# Segredo para assinar cookies de sessão — IMPORTANTE: defina um valor fixo aqui.
# Se você rodar às vezes local (uvicorn) e às vezes via Docker sem fixar isso,
# cada modo pode usar um valor padrão diferente e suas sessões de login "quebram"
# (você é deslogado sempre que troca de um modo pro outro). Gere o seu com:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=pU7XdpB06UGvAJO1S9-cd79Z9tKAIfTtmFJ1z7nxXUI

# Banco de dados (SQLite por padrão; troque para Postgres em produção)
DATABASE_URL=sqlite:///./dumpai.db

# Quantidade de perguntas respondidas antes de reavaliar o nível do usuário
QUESTIONS_PER_EVALUATION=5

# URL pública onde o app está acessível — usada nos links dos e-mails
# (confirmação de cadastro, botão "Entrar agora"). Troque para o domínio/IP
# real quando for pra produção (ex: https://dumpai.seudominio.com).
APP_BASE_URL=http://localhost:8000

# --- E-mail (confirmação de cadastro e recuperação de senha) ---
# Recomendado: Brevo (https://www.brevo.com), tier gratuito com 300 e-mails/dia,
# sem cartão de crédito. Passo a passo no README.md.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=seu-login-smtp-da-brevo
SMTP_PASSWORD=sua-chave-smtp-da-brevo
EMAIL_FROM=no-reply@seudominio.com
EMAIL_FROM_NAME=DumpAI
